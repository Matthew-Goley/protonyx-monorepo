# Shared Postgres instance — the SAME database the Fastify backend uses.
# The referral service owns only the `waitlist` table and writes `users` solely
# via POST /redeem. Format: postgresql://<user>:<pass>@<host>:<port>/<db>
# If your provider requires TLS, append ?sslmode=require
DATABASE_URL="postgresql://user:pass@host:5432/db"

# Resend transactional email (magic-link verification).
RESEND_API_KEY="change-me"
# FROM address. noreply@protonyxdata.com is the currently verified Resend domain.
# To send from noreply@lens-arc.com, verify lens-arc.com in Resend first.
RESEND_FROM="noreply@protonyxdata.com"

# Where magic links point. The link is {FRONTEND_BASE_URL}/verify?token=...
# Dev: http://localhost:5173  |  Prod: https://lens-arc.com
FRONTEND_BASE_URL="http://localhost:5173"

# Display base for the share link shown in the UI (no scheme, matches content.ts).
REFERRAL_LINK_BASE="lens-arc.com/r/"

# Single-use magic-token lifetime, in minutes.
MAGIC_LINK_TTL_MINUTES="30"

# Shared secret guarding the internal POST /redeem endpoint (X-Redeem-Secret
# header). Never called by the marketing site. Use a long random string.
REDEEM_SECRET="change-me-to-a-long-random-string"
